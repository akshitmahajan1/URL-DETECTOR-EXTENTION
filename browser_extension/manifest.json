
{
  "manifest_version": 3,
  "name": "Phishing & Malware URL Detector",
  "version": "0.1.0",
  "description": "Checks visited URLs against a local AI model backend and warns on suspicious sites.",
  "permissions": [
    "webNavigation",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
  "<all_urls>",
  "http://127.0.0.1:8080/*"
  ]
}